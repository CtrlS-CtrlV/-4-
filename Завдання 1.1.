import threading
import time

def download_simulation(file_name: str, size_mb: float) -> dict:
    thread_name = threading.current_thread().name
    print(f"[{thread_name}] Початок завантаження '{file_name}' ({size_mb} MB)...")
    
    # Імітація завантаження: 1 секунда на 1 MB
    time.sleep(size_mb) 
    
    print(f"[{thread_name}] Завершено '{file_name}'")
    return {"file": file_name, "size": size_mb, "thread": thread_name}

class MonitorThread(threading.Thread):
    def __init__(self, interval: float = 1.0):
        super().__init__(name="Monitor", daemon=True)
        self.interval = interval
        self._stop_event = threading.Event()

    def run(self):
        while not self._stop_event.is_set():
            # -1 бо не рахуємо сам потік-монітор
            print(f"\n[MONITOR] Активних потоків: {threading.active_count() - 1}")
            time.sleep(self.interval)

    def stop(self):
        self._stop_event.set()

def main():
    files = [("data.csv", 2.5), ("report.pdf", 1.0), ("image.png", 0.5), 
             ("archive.zip", 4.0), ("log.txt", 0.3)]

    monitor = MonitorThread(interval=0.5)
    monitor.start()

    # Послідовне виконання для порівняння
    print("--- Послідовне виконання ---")
    start_seq = time.perf_counter()
    for f, s in files:
        download_simulation(f, s)
    elapsed_seq = time.perf_counter() - start_seq

    # Паралельне виконання
    print("\n--- Паралельне виконання ---")
    threads = []
    start_par = time.perf_counter()
    for f, s in files:
        t = threading.Thread(target=download_simulation, args=(f, s))
        threads.append(t)
        t.start()

    for t in threads:
        t.join()
    
    elapsed_par = time.perf_counter() - start_par
    monitor.stop()

    print(f"\nПослідовно: {elapsed_seq:.2f} сек")
    print(f"Паралельно: {elapsed_par:.2f} сек")
    print(f"Прискорення: {elapsed_seq / elapsed_par:.2f}x")

if __name__ == "__main__":
    main()
