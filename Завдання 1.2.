import multiprocessing
import time
import os

def is_prime(n: int) -> bool:
    if n < 2: return False
    for i in range(2, int(n**0.5) + 1):
        if n % i == 0: return False
    return True

def sum_primes_in_range(start: int, end: int) -> tuple[int, int, int]:
    pid = os.getpid()
    primes = [i for i in range(start, end) if is_prime(i)]
    return (sum(primes), len(primes), pid)

def main():
    total_range = 1_000_000
    num_workers = multiprocessing.cpu_count()

    chunk_size = total_range // num_workers
    ranges = [(i * chunk_size, (i + 1) * chunk_size) for i in range(num_workers)]

    # Послідовно
    start_time = time.perf_counter()
    res_seq = sum_primes_in_range(2, total_range)
    seq_time = time.perf_counter() - start_time

    # Паралельно
    start_time = time.perf_counter()
    with multiprocessing.Pool(processes=num_workers) as pool:
        results = pool.starmap(sum_primes_in_range, ranges)
    par_time = time.perf_counter() - start_time

    for res in results:
        print(f"PID {res[2]} обробив частину. Знайдено: {res[1]} чисел.")

    print(f"\nПослідовно: {seq_time:.3f} сек")
    print(f"Паралельно ({num_workers} ядра): {par_time:.3f} сек")
    print(f"Прискорення: {seq_time / par_time:.2f}x")

if __name__ == "__main__":
    main()
