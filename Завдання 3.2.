import threading
import queue
import time

def deadlock_demo():
    lock_a = threading.Lock()
    lock_b = threading.Lock()

    def worker_1():
        print("W1 чекає Lock A")
        with lock_a:
            print("W1 взяв Lock A, чекає Lock B")
            time.sleep(0.5)
            if lock_b.acquire(timeout=2):
                print("W1 взяв Lock B")
                lock_b.release()
            else:
                print("W1: ДЕДЛОК ВИЯВЛЕНО (timeout)")

    def worker_2():
        print("W2 чекає Lock B")
        with lock_b:
            print("W2 взяв Lock B, чекає Lock A")
            time.sleep(0.5)
            if lock_a.acquire(timeout=2):
                print("W2 взяв Lock A")
                lock_a.release()
            else:
                print("W2: ДЕДЛОК ВИЯВЛЕНО (timeout)")

    t1 = threading.Thread(target=worker_1)
    t2 = threading.Thread(target=worker_2)
    t1.start(); t2.start()
    t1.join(); t2.join()
